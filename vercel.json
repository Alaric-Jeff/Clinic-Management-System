{
  "version": 2,
  "functions": {
    "backend/api/index.ts": {
      "runtime": "@vercel/node",
      "includeFiles": "backend/prisma/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/:match*",
      "destination": "/backend/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}